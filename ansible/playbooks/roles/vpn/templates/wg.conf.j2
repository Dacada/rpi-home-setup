# {{ ansible_managed }}

[Interface]
PrivateKey = {{ vpn.wg_private_key_server }}
Address = {{ wg_server_vpn_ip }}/24
ListenPort = 51820  # REMINDER: THIS IS UDP
PostUp = iptables -t nat -A POSTROUTING -s {{ wg_admin_subnet }} -o {{ wg_network_interface }} -j SNAT --to-source {{ wg_server_lan_ip }}; iptables -A FORWARD -i wg0 -s {{ wg_admin_subnet }} -d {{ wg_lan_subnet }} -j ACCEPT; iptables -A FORWARD -o wg0 -d {{ wg_admin_subnet }} -s {{ wg_lan_subnet }} -j ACCEPT; iptables -A INPUT -i wg0 -j LOG --log-prefix "WireGuard-Connection: "
PostDown = iptables -t nat -D POSTROUTING -s {{ wg_admin_subnet }} -o {{ wg_network_interface }} -j SNAT --to-source {{ wg_server_lan_ip }}; iptables -D FORWARD -i wg0 -s {{ wg_admin_subnet }} -d {{ wg_lan_subnet }} -j ACCEPT; iptables -D FORWARD -o wg0 -d {{ wg_admin_subnet }} -s {{ wg_lan_subnet }} -j ACCEPT; iptables -D INPUT -i wg0 -j LOG --log-prefix "WireGuard-Connection: "

# Infrastructure (10.69.42.0/27)
[Peer]
PublicKey = {{ vpn.wg_public_key_pihole }}
AllowedIPs = 10.69.42.2/32
PersistentKeepalive = 25

