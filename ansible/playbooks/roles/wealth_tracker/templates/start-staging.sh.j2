#!/bin/bash
# {{ ansible_managed }}
set -euo pipefail

# Require image tag as argument
if [ $# -lt 1 ]; then
    echo "Usage: $0 <image-tag>"
    echo "Example: $0 registry.gitlab.com/dacada/wealth-tracker:abc123def456"
    exit 1
fi

TAG="$1"
PROD_DB="/mnt/files/wealth_tracker"
STAGING_DB="/mnt/files/wealth_tracker_staging"
RAILS_MASTER_KEY="{{ wealth_tracker.rails_master_key }}"

# Warn if staging DB exists
if [ -d "$STAGING_DB" ]; then
    echo "⚠️  WARNING: Staging database already exists at $STAGING_DB"
    echo "⚠️  It will be overwritten by copying from prod..."
fi

echo "Stopping prod..."
systemctl stop wealth_tracker.service

echo "Copying prod DB to staging..."
rm -rf "$STAGING_DB"
cp -r "$PROD_DB" "$STAGING_DB"

echo "Starting prod..."
systemctl start wealth_tracker.service

echo "Pulling image: $TAG"
docker pull "$TAG"

echo "Starting staging container on port 3001..."
docker run -d --name wealth_tracker_staging -p 3001:3000 \
    -e RAILS_MASTER_KEY="$RAILS_MASTER_KEY" \
    -v "$STAGING_DB":/data "$TAG"

echo "Staging server is running on port 3001"
